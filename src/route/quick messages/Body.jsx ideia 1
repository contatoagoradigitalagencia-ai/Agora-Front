import { useState } from "react";

export default function Body({ socket }) {
    const [messages, setMessages] = useState([]);
    const [selectedId, setSelectedId] = useState(null);
    const [view, setView] = useState("list");

    const selected = messages.find(m => m.id === selectedId);

    function handleNew() {
        const newMsg = {
            id: Date.now(),
            name: "Nova mensagem",
            type: "text",
            content: "",
            mediaUrl: "",
            caption: ""
        };

        setMessages(prev => [newMsg, ...prev]);
        setSelectedId(newMsg.id);
        setView("editor");
    }

    function handleSelect(id) {
        setSelectedId(id);
        setView("editor");
    }

    function handleUpdate(field, value) {
        setMessages(prev =>
            prev.map(msg =>
                msg.id === selectedId ? { ...msg, [field]: value } : msg
            )
        );
    }

    function handleDelete(id) {
        setMessages(prev => prev.filter(m => m.id !== id));
        setView("list");
    }

    return (
        <div className="p-4 sm:p-6 flex flex-col xl:flex-row gap-4 xl:gap-6 h-full min-h-0 overflow-hidden">

            {/* SIDEBAR */}
            <div className={`
                ${view === "list" ? "flex" : "hidden"} 
                xl:flex flex-col w-full xl:w-72 2xl:w-80
                bg-zinc-900 border border-zinc-800 rounded-lg p-3
                min-h-0
            `}>

                {/* HEADER */}
                <div className="flex flex-col gap-3">
                    <button
                        onClick={handleNew}
                        className="bg-orange-500 text-black rounded p-2 text-sm"
                    >
                        + Nova mensagem
                    </button>

                    <input
                        placeholder="Buscar..."
                        className="bg-zinc-800 border border-zinc-700 rounded p-2 text-sm outline-none"
                    />
                </div>

                {/* LISTA */}
                <div className="flex flex-col gap-2 mt-3 overflow-y-auto flex-1 min-h-0 pr-1">
                    {messages.map(msg => (
                        <div
                            key={msg.id}
                            onClick={() => handleSelect(msg.id)}
                            className={`p-3 rounded border cursor-pointer ${
                                selectedId === msg.id
                                    ? "bg-zinc-800 border-orange-500"
                                    : "bg-zinc-900 border-zinc-800"
                            }`}
                        >
                            <p className="text-sm font-medium">{msg.name}</p>
                            <p className="text-xs text-zinc-400 line-clamp-1">
                                {msg.type === "text"
                                    ? msg.content
                                    : msg.caption || msg.mediaUrl}
                            </p>
                        </div>
                    ))}
                </div>
            </div>

            {/* EDITOR */}
            <div className={`
                ${view === "editor" ? "flex" : "hidden"} 
                xl:flex flex-1 flex-col 
                bg-zinc-900 border border-zinc-800 rounded-lg p-4 gap-4
                h-full
            `}>

                {!selected && (
                    <div className="flex flex-1 items-center justify-center text-zinc-500 text-sm">
                        Selecione ou crie uma mensagem
                    </div>
                )}

                {selected && (
                    <>
                        {/* MOBILE BACK */}
                        <button
                            onClick={() => setView("list")}
                            className="xl:hidden text-sm text-orange-500"
                        >
                            ← Voltar
                        </button>

                        {/* HEADER */}
                        <div className="flex justify-between gap-2">
                            <input
                                className="bg-zinc-800 border border-zinc-700 rounded p-2 text-sm outline-none flex-1"
                                value={selected.name}
                                onChange={(e) => handleUpdate("name", e.target.value)}
                            />

                            <button
                                onClick={() => handleDelete(selected.id)}
                                className="text-zinc-400 hover:text-red-500"
                            >
                                <i className="bi bi-trash text-lg" />
                            </button>
                        </div>

                        {/* TYPE */}
                        <div className="flex gap-2 flex-wrap">
                            {["text", "image", "video"].map(type => (
                                <button
                                    key={type}
                                    onClick={() => handleUpdate("type", type)}
                                    className={`px-3 py-1 rounded text-sm border ${
                                        selected.type === type
                                            ? "bg-orange-500 text-black border-orange-500"
                                            : "border-zinc-700 text-zinc-400"
                                    }`}
                                >
                                    {type === "text" && "Texto"}
                                    {type === "image" && "Imagem"}
                                    {type === "video" && "Vídeo"}
                                </button>
                            ))}
                        </div>

                        {/* CONTENT */}
                        {selected.type === "text" && (
                            <textarea
                                className="bg-zinc-800 border border-zinc-700 rounded p-2 text-sm min-h-[120px]"
                                placeholder="Digite a mensagem..."
                                value={selected.content}
                                onChange={(e) => handleUpdate("content", e.target.value)}
                            />
                        )}

                        {selected.type !== "text" && (
                            <>
                                <input
                                    className="bg-zinc-800 border border-zinc-700 rounded p-2 text-sm"
                                    placeholder="URL da mídia"
                                    value={selected.mediaUrl}
                                    onChange={(e) => handleUpdate("mediaUrl", e.target.value)}
                                />

                                <textarea
                                    className="bg-zinc-800 border border-zinc-700 rounded p-2 text-sm min-h-[80px]"
                                    placeholder="Legenda (caption)"
                                    value={selected.caption}
                                    onChange={(e) => handleUpdate("caption", e.target.value)}
                                />
                            </>
                        )}

                        {/* PREVIEW */}
                        <div className="bg-zinc-800 border border-zinc-700 rounded p-3 flex flex-col gap-3">
                            <p className="text-xs text-zinc-400">Preview</p>

                            <div className="max-h-60 overflow-y-auto pr-1">
                                
                                {selected.type === "text" && (
                                    <div className="bg-green-600 text-white text-sm p-3 rounded-lg max-w-xs break-words">
                                        {selected.content || "Preview..."}
                                    </div>
                                )}

                                {selected.type === "image" && selected.mediaUrl && (
                                    <div className="flex flex-col gap-2 max-w-xs">
                                        <img src={selected.mediaUrl} className="rounded" />
                                        {selected.caption && (
                                            <div className="bg-green-600 text-white text-sm p-2 rounded-lg break-words">
                                                {selected.caption}
                                            </div>
                                        )}
                                    </div>
                                )}

                                {selected.type === "video" && selected.mediaUrl && (
                                    <div className="flex flex-col gap-2 max-w-xs">
                                        <video src={selected.mediaUrl} controls className="rounded" />
                                        {selected.caption && (
                                            <div className="bg-green-600 text-white text-sm p-2 rounded-lg break-words">
                                                {selected.caption}
                                            </div>
                                        )}
                                    </div>
                                )}
                            </div>
                        </div>
                    </>
                )}
            </div>
        </div>
    );
}